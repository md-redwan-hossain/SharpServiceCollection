<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>netstandard2.0</TargetFramework>
        <LangVersion>latest</LangVersion>
        <Nullable>enable</Nullable>
        <Version>1.0.1</Version>
        <Title>SharpServiceCollection</Title>
        <Authors>Md. Redwan Hossain</Authors>
        <Copyright>Copyright (c) Md. Redwan Hossain</Copyright>
        <PackageProjectUrl>https://github.com/md-redwan-hossain/SharpServiceCollection</PackageProjectUrl>
        <PackageIcon>logo.png</PackageIcon>
        <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
        <RepositoryUrl>https://github.com/md-redwan-hossain/SharpServiceCollection</RepositoryUrl>
        <PackageTags>dependency injection ioc inversion di aot source generation assembly scanning</PackageTags>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <NoWarn>CS1591</NoWarn>
        <DocumentationFile Condition="'$(Configuration)'=='Release'">bin\$(Configuration)\$(TargetFramework)\SharpServiceCollection.xml</DocumentationFile>
        <Description>SharpServiceCollection is a lightweight C# library that provides declarative workflow for IServiceCollection.</Description>
        <TargetsForTfmSpecificBuildOutput>$(TargetsForTfmSpecificBuildOutput);CopyProjectReferencesToPackage</TargetsForTfmSpecificBuildOutput>
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="..\SharpServiceCollection.Dependencies\SharpServiceCollection.Dependencies.csproj"
                          PrivateAssets="all"
        />
        <!-- Consider adding ReferenceOutputAssembly="false" below if your main library
             never references types from Generators directly at compile time. -->
        <ProjectReference Include="..\SharpServiceCollection.Generators\SharpServiceCollection.Generators.csproj"
                          PrivateAssets="all" ReferenceOutputAssembly="false"
        />
    </ItemGroup>

    <!-- Bundle the supporting assemblies into this single consumer package. -->
    <ItemGroup>
        <None Include="..\SharpServiceCollection.Generators\bin\$(Configuration)\$(TargetFramework)\SharpServiceCollection.Generators.dll"
              Pack="true"
              PackagePath="analyzers\dotnet\cs"
              Visible="false"/>
        <!-- Only needed here too if the generator itself calls into Dependencies at compile time
             (Roslyn only loads DLLs from analyzers/dotnet/cs, not from lib/). -->
        <None Include="..\SharpServiceCollection.Dependencies\bin\$(Configuration)\$(TargetFramework)\SharpServiceCollection.Dependencies.dll"
              Pack="true"
              PackagePath="analyzers\dotnet\cs"
              Visible="false"/>
    </ItemGroup>

    <ItemGroup>
        <None Include="..\..\logo.png">
            <Pack>True</Pack>
            <PackagePath>.</PackagePath>
            <Link>logo.png</Link>
        </None>
    </ItemGroup>

    <ItemGroup>
        <None Include="..\..\README.md">
            <Pack>True</Pack>
            <Link>README.md</Link>
            <PackagePath>.</PackagePath>
        </None>
    </ItemGroup>

    <Target Name="CopyProjectReferencesToPackage" DependsOnTargets="BuildOnlySettings;ResolveReferences">
        <ItemGroup>
            <_ReferenceCopyLocalPaths Include="@(ReferenceCopyLocalPaths->WithMetadataValue('ReferenceSourceTarget', 'ProjectReference')->WithMetadataValue('PrivateAssets', 'All')->WithMetadataValue('Filename', 'SharpServiceCollection.Dependencies'))"/>
            <BuildOutputInPackage Include="@(_ReferenceCopyLocalPaths)" TargetPath="%(_ReferenceCopyLocalPaths.DestinationSubDirectory)"/>
        </ItemGroup>
    </Target>

</Project>